---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Andrés de la Rosa Sánchez — Consagrado al Sagrado Corazón de Jesús',
  description = 'Reflexiones diarias de fe, esperanza y amor.',
} = Astro.props;

const siteName = 'Andrés de la Rosa Sánchez';
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <header class="site-header">
    <a href="/">
      <p class="site-consecrated">CONSAGRADO AL SAGRADO CORAZÓN DE JESÚS</p>
      <h1 class="site-title">Andrés de la Rosa Sánchez</h1>
      <p class="site-subtitle">Reflexiones diarias de fe, esperanza y amor</p>
    </a>
  </header>

  <span class="ornament">✝</span>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
  <p class="footer-devotion">SAGRADO CORAZÓN DE JESÚS, EN VOS CONFÍO</p>
</footer>
</body>
</html>
